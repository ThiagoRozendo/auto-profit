generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["vehicle"]
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  IN_MAINTENANCE
  SOLD

  @@schema("vehicle")
}

model Vehicle {
  id            String        @id @default(uuid()) @db.Uuid
  ownerId       String        @db.Uuid
  brand         String
  model         String
  year          Int
  plate         String        @unique
  purchasePrice Decimal       @db.Decimal(12, 2)
  status        VehicleStatus @default(AVAILABLE)
  observations  String?
  soldAt        DateTime?
  salePrice     Decimal?      @db.Decimal(12, 2)
  saleNotes     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([plate])
  @@schema("vehicle")
}
